<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->

    <!-- Dark gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_dark_overlay" />

    <!-- Top branding -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="72dp"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:src="@mipmap/ic_launcher_round"
            android:elevation="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="BloodDrop"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Every drop saves a life"
            android:textColor="#CCFFFFFF"
            android:textSize="15sp"
            android:letterSpacing="0.02" />

        <!-- Decorative red accent line -->
        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:layout_marginTop="14dp"
            android:background="#D70404" />

    </LinearLayout>

    <!-- Bottom Action Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="48dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="20dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Who are you?"
                android:textColor="#1A1A1A"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="22dp"
                android:text="Select your role to get started"
                android:textColor="#888888"
                android:textSize="13sp" />

            <!-- User Button filled red -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUser"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Continue as User"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                app:backgroundTint="#D70404"
                app:cornerRadius="14dp"
                app:rippleColor="#FF8A80"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconGravity="start"
                app:iconTint="#FFFFFF" />

            <!-- Admin Button outlined -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdmin"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:text="Continue as Admin"
                android:textColor="#D70404"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                app:cornerRadius="14dp"
                app:strokeColor="#D70404"
                app:strokeWidth="2dp"
                app:rippleColor="#FFEBEE"
                app:icon="@android:drawable/ic_menu_manage"
                app:iconGravity="start"
                app:iconTint="#D70404" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="Powered by BloodDrop — Saving Lives Together"
                android:textColor="#BBBBBB"
                android:textSize="11sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>