<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/bg_gradient_login"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Donation Certificate"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Thank you for saving a life"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Certificate WebView -->
    <WebView
        android:id="@+id/webViewCertificate"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp" />

    <!-- Download / Print Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPrint"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        android:text="Save / Print Certificate"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#D70404"
        app:cornerRadius="12dp"
        app:rippleColor="#FF8A80"
        app:icon="@android:drawable/ic_menu_save"
        app:iconGravity="start"
        app:iconTint="#FFFFFF" />

</LinearLayout>