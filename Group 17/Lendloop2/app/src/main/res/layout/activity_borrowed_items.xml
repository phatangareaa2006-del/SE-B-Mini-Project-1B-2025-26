<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/borrowedHeader"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:background="@drawable/bg_gradient"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📦 My Borrowed Items"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Items you are currently borrowing"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerBorrowed"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/borrowedHeader"
        android:padding="12dp"
        android:clipToPadding="false"/>

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="📭&#10;You haven't borrowed any items yet."
        android:textSize="16sp"
        android:textColor="#999999"
        android:gravity="center"
        android:visibility="gone"/>

</RelativeLayout>