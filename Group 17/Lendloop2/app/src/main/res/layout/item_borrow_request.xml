<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginTop="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="1dp"
    app:strokeColor="#F0F0F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Name and Status -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/llReqName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/tvRequestStatus">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_person"
                    app:tint="#1976D2"/>

                <TextView
                    android:id="@+id/tvRequestName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Requester Name"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvRequestStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="#F57C00"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Pending"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </RelativeLayout>

        <!-- Contact Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_call"
                app:tint="#555555"/>

            <TextView
                android:id="@+id/tvRequestContact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Contact Number"
                android:textColor="#666666"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Email Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_email"
                app:tint="#64B5F6"/>

            <TextView
                android:id="@+id/tvRequestEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Email Address"
                android:textColor="#666666"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Date Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_calendar"
                app:tint="#E53935"/>

            <TextView
                android:id="@+id/tvRequestDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Requested on: date"
                android:textColor="#888888"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Approve/Reject Buttons -->
        <LinearLayout
            android:id="@+id/llApproveRejectButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="end">

            <Button
                android:id="@+id/btnRejectRequest"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Reject"
                android:textSize="12sp"
                android:textColor="#D32F2F"
                app:strokeColor="#D32F2F"
                android:layout_marginEnd="8dp"
                app:cornerRadius="8dp"/>

            <Button
                android:id="@+id/btnApproveRequest"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Approve"
                android:textSize="12sp"
                android:backgroundTint="#388E3C"
                app:cornerRadius="8dp"/>
        </LinearLayout>

        <!-- Resolve/Return Section -->
        <LinearLayout
            android:id="@+id/llResolveRequest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/etRequestFine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fine Amount (if applicable)"
                android:textSize="13sp"
                android:inputType="number"
                android:background="@drawable/input_rounded"
                android:padding="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp">

                <Button
                    android:id="@+id/btnMarkReturned"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="✅ Mark as Returned"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="#1565C0"
                    app:cornerRadius="8dp"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnMarkBroken"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:text="💔 Mark as Broken"
                    android:textSize="12sp"
                    android:textColor="#D32F2F"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
