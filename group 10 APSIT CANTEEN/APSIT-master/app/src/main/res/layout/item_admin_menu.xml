<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_admin_card"
    android:orientation="horizontal">

    <!-- Left Accent Bar -->
    <View
        android:id="@+id/viewAccent"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="#D4A017" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvItemName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Item Name"
                android:textColor="#1A1A1A"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvCategoryBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#D8F3DC"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Category"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="₹0"
            android:textColor="#D4A017"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Stock: 0 units"
            android:textColor="#5A5A5A"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingEnd="12dp">

        <Switch
            android:id="@+id/swAvailable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="0.8"
            android:scaleY="0.8" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_edit_btn"
                android:src="@android:drawable/ic_menu_edit"
                android:layout_marginEnd="8dp"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_danger_btn"
                android:src="@android:drawable/ic_menu_delete"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:tint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
