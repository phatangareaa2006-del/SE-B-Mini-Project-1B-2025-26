<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_landing_gradient">

    <!-- Top Section: Logo and Title -->
    <LinearLayout
        android:id="@+id/logoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Logo Placeholder -->
        <View
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/ic_food_placeholder"
            android:padding="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="serif"
            android:text="@string/app_name"
            android:textColor="@color/colorAccent"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.7"
            android:text="@string/tagline"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <View
            android:layout_width="80dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/colorAccent" />
    </LinearLayout>

    <!-- Bottom Section: Actions -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="60dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:alpha="0.6"
            android:text="@string/continue_as"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnStudentLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_gold_button"
            android:text="@string/student_login"
            android:textAllCaps="false"
            android:textColor="@color/colorTextOnAccent"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnAdminLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_outlined_gold_button"
            android:text="@string/admin_login"
            android:textAllCaps="false"
            android:textColor="@color/colorAccent"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvCreateAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/new_here_create"
            android:textColor="@color/colorAccent"
            android:textSize="14sp" />
    </LinearLayout>

</RelativeLayout>