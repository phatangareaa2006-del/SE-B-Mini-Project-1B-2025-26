<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F0">

    <!-- TOOLBAR -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1B4332"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF"
            android:rotation="180"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Reports &amp; Analytics"
            android:textColor="#D4A017"
            android:textSize="18sp"
            android:fontFamily="serif"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- SECTION A: Summary Cards -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2">

                <!-- Card 1: 7-Day Revenue -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7-Day Revenue"
                        android:textColor="#5A5A5A"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tvTotalRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹12,450"
                        android:textColor="#D4A017"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Card 2: Total Orders -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Orders"
                        android:textColor="#5A5A5A"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tvTotalOrdersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="156"
                        android:textColor="#D4A017"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Card 3: Avg Order Value -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg. Order Value"
                        android:textColor="#5A5A5A"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tvAvgOrderValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹85"
                        android:textColor="#D4A017"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Card 4: Top Item -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Top Selling"
                        android:textColor="#5A5A5A"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tvTopSellingItem"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Samosa"
                        android:textColor="#D4A017"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:ellipsize="end"
                        android:maxLines="1" />
                </LinearLayout>
            </GridLayout>

            <!-- SECTION B: Bar Chart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_admin_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Revenue — Last 7 Days"
                    android:textColor="#1B4332"
                    android:textSize="16sp"
                    android:fontFamily="serif"
                    android:textStyle="bold" />

                <com.example.apsitcanteen.views.BarChartView
                    android:id="@+id/revenueBarChart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />
            </LinearLayout>

            <!-- SECTION C: Order Status Breakdown -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_admin_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Order Status Breakdown"
                    android:textColor="#1B4332"
                    android:textSize="16sp"
                    android:fontFamily="serif"
                    android:textStyle="bold" />

                <!-- Multi-color Segmented Bar -->
                <LinearLayout
                    android:id="@+id/statusBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:orientation="horizontal"
                    android:background="#E0E0E0">
                    <View android:id="@+id/viewPending" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F0C040" />
                    <View android:id="@+id/viewPreparing" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#378ADD" />
                    <View android:id="@+id/viewReady" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#2D6A4F" />
                    <View android:id="@+id/viewCompleted" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#1B4332" />
                    <View android:id="@+id/viewCancelled" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#C0392B" />
                </LinearLayout>

                <!-- Legend -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:columnCount="2">

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_margin="4dp">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="#F0C040" />
                        <TextView android:id="@+id/tvPendingLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending (3)" android:textSize="12sp" android:layout_marginStart="6dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_margin="4dp">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="#378ADD" />
                        <TextView android:id="@+id/tvPreparingLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Preparing (2)" android:textSize="12sp" android:layout_marginStart="6dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_margin="4dp">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="#2D6A4F" />
                        <TextView android:id="@+id/tvReadyLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ready (1)" android:textSize="12sp" android:layout_marginStart="6dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_margin="4dp">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="#1B4332" />
                        <TextView android:id="@+id/tvCompletedLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Completed (3)" android:textSize="12sp" android:layout_marginStart="6dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_margin="4dp">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="#C0392B" />
                        <TextView android:id="@+id/tvCancelledLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cancelled (1)" android:textSize="12sp" android:layout_marginStart="6dp" />
                    </LinearLayout>
                </GridLayout>
            </LinearLayout>

            <!-- SECTION D: Horizontal Bar Chart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_admin_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Top Selling Items"
                    android:textColor="#1B4332"
                    android:textSize="16sp"
                    android:fontFamily="serif"
                    android:textStyle="bold" />

                <com.example.apsitcanteen.views.HorizontalBarChartView
                    android:id="@+id/topItemsChart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- SECTION E: Transaction History -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_admin_card"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    android:text="Recent Transactions"
                    android:textColor="#1B4332"
                    android:textSize="16sp"
                    android:fontFamily="serif"
                    android:textStyle="bold" />

                <!-- Table Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1B4332"
                    android:paddingVertical="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ID" android:textColor="#F0C040" android:gravity="center" android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Student" android:textColor="#F0C040" android:gravity="center" android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Amount" android:textColor="#F0C040" android:gravity="center" android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="Status" android:textColor="#F0C040" android:gravity="center" android:textSize="11sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/transactionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <Button
                    android:id="@+id/btnExport"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_margin="16dp"
                    android:text="Export Full Report (CSV)"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_action_btn" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
